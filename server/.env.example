# =============================================================
# Salio Server — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# In production, set these as platform environment variables
# (Docker env, systemd EnvironmentFile, Kubernetes Secret, etc.)
# =============================================================

# --- Server ---
PORT=8080
APP_ENV=development   # change to "production" in prod (enables JSON logs, strict mode)

# --- Database (PostgreSQL) ---
# Use separate fields instead of a single DATABASE_URL:
# - Easier to rotate passwords without rebuilding URLs
# - Works with Docker port mapping (host port != container port)
DB_HOST=127.0.0.1
# If Postgres is in Docker, use the HOST port (e.g. 5434 if mapped 5434->5432)
DB_PORT=5432
DB_NAME=salio_db
DB_USER=root
DB_PASSWORD=root
DB_SSLMODE=disable    # use "require" in production with TLS-enabled Postgres

# --- JWT Authentication ---
# Must be at least 32 characters. Use a random generator:
# openssl rand -hex 32
JWT_SECRET=change-me-to-a-real-secret-at-least-32-chars
JWT_EXPIRY_HOURS=720   # 30 days; reduce to 24 for higher security

# --- CORS (Cross-Origin Resource Sharing) ---
# Comma-separated list of allowed origins for browser clients.
# Use "*" in development. Set specific origins in production.
# Example: https://app.salio.co.ke,https://admin.salio.co.ke
CORS_ALLOWED_ORIGINS=*

# --- Rate Limiting (per IP, token bucket algorithm) ---
# RATE_LIMIT_RPS:   steady request rate (requests per second)
# RATE_LIMIT_BURST: spike allowance above RPS (e.g. app startup loads many things at once)
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# --- Request Timeout ---
# Maximum seconds a single request can take before the server cancels it.
# Prevents slow clients from holding database connections indefinitely.
REQUEST_TIMEOUT_SECS=30
